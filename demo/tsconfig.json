{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "types": ["node"],
        "noEmit": true,
        "noUncheckedIndexedAccess": false,
        "jsx": "react-jsx"
    },
    "include": ["src/**/*", "test/**/*", "vite.config.ts", "vite.p2p-test.config.ts", "playwright.config.ts"],
    "ts-node": {
        "transpileOnly": true,
        "compilerOptions": {
            "module": "CommonJS",
            "moduleResolution": "Node",
            "declaration": false,
            "rootDir": "src"
        }
    }
}
