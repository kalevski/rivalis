{
    "name": "@rivalis/signal",
    "version": "0.1.0",
    "description": "Signaling server for Rivalis P2P: WebRTC SDP/ICE relay and TURN credential issuance",
    "source": "src/main.ts",
    "main": "lib/main.js",
    "module": "lib/module.js",
    "types": "lib/main.d.ts",
    "exports": {
        ".": {
            "types": "./lib/main.d.ts",
            "import": "./lib/module.js",
            "require": "./lib/main.js"
        }
    },
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "dev": "tsup --watch",
        "build": "tsup",
        "test": "npm run build && node --test \"test/**/*.test.mts\""
    },
    "peerDependencies": {
        "@rivalis/core": ">=7 <8",
        "@rivalis/handshake": ">=6 <7",
        "@toolcase/base": "3.x",
        "@toolcase/logging": "3.x",
        "ws": "8.x"
    },
    "devDependencies": {
        "@rivalis/core": "*",
        "@rivalis/handshake": "*"
    },
    "keywords": [
        "realtime",
        "webrtc",
        "signaling",
        "p2p",
        "multiplayer",
        "rivalis"
    ],
    "directories": {
        "lib": "lib"
    },
    "files": [
        "lib"
    ],
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kalevski/rivalis.git"
    },
    "author": {
        "name": "kalevski"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/kalevski/rivalis/issues"
    },
    "homepage": "https://github.com/kalevski/rivalis#readme"
}
