{
    "name": "@rivalis/handshake",
    "version": "8.0.0",
    "private": true,
    "description": "Wire-format and protocol primitives shared between @rivalis/core and @rivalis/browser",
    "source": "src/main.ts",
    "main": "lib/main.js",
    "module": "lib/module.js",
    "types": "lib/main.d.ts",
    "exports": {
        ".": {
            "types": "./lib/main.d.ts",
            "import": "./lib/module.js",
            "require": "./lib/main.js"
        }
    },
    "scripts": {
        "dev": "tsup --watch",
        "build": "tsup",
        "test": "npm run build && node --test \"test/**/*.test.mts\" && node --input-type=module -e \"import '@rivalis/handshake'\""
    },
    "files": [
        "lib"
    ]
}
