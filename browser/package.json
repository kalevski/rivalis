{
    "name": "@rivalis/browser",
    "version": "5.0.6",
    "description": "🔗 Browser client for rivalis server",
    "source": "src/main.ts",
    "main": "lib/main.js",
    "module": "lib/module.js",
    "types": "lib/main.d.ts",
    "exports": {
        ".": {
            "types": "./lib/main.d.ts",
            "import": "./lib/module.js",
            "require": "./lib/main.js"
        }
    },
    "scripts": {
        "dev": "tsup --watch",
        "build": "tsup"
    },
    "peerDependencies": {
        "@toolcase/base": "2.x",
        "@toolcase/logging": "2.x",
        "@toolcase/serializer": "2.x"
    },
    "devDependencies": {
        "@rivalis/handshake": "*"
    },
    "keywords": ["realtime", "websockets", "networking", "multiplayer", "netcode", "toolcase", "borwser", "rivalis"],
    "directories": {
        "lib": "lib"
    },
    "files": [
        "lib"
    ],
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kalevski/rivalis.git"
    },
    "author": {
        "name": "kalevski"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/kalevski/rivalis/issues"
    },
    "homepage": "https://github.com/kalevski/rivalis#readme"
}
