{
    "name": "@rivalis/browser",
    "version": "8.0.0",
    "description": "\ud83d\udd17 Browser client for rivalis server",
    "source": "src/main.ts",
    "main": "lib/main.js",
    "module": "lib/module.js",
    "types": "lib/main.d.ts",
    "exports": {
        ".": {
            "types": "./lib/main.d.ts",
            "import": "./lib/module.js",
            "require": "./lib/main.js"
        }
    },
    "scripts": {
        "dev": "tsup --watch",
        "build": "tsup",
        "test": "npm run build && node --test \"test/**/*.test.mts\""
    },
    "peerDependencies": {
        "@rivalis/core": ">=8 <9",
        "@toolcase/base": "3.x",
        "@toolcase/logging": "3.x"
    },
    "devDependencies": {
        "@rivalis/core": "*",
        "@rivalis/handshake": "*"
    },
    "keywords": [
        "realtime",
        "websockets",
        "networking",
        "multiplayer",
        "netcode",
        "toolcase",
        "borwser",
        "rivalis"
    ],
    "directories": {
        "lib": "lib"
    },
    "files": [
        "lib"
    ],
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kalevski/rivalis.git"
    },
    "author": {
        "name": "kalevski"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/kalevski/rivalis/issues"
    },
    "homepage": "https://github.com/kalevski/rivalis#readme"
}
