# @rivalis/fleet — environment surface (§12).
# Every variable read by the orchestrator binary is declared here and in
# src/env.ts (the single typed env home). Secrets are left empty; tunables show
# their defaults. Flags (rivalis-fleet --flag) override these.

# 'production' enforces the §12/§13 refuse-to-start rules (key strength,
# agent/admin audience separation, no auto-generated keys).
NODE_ENV=

# ── Networking (§12) ──────────────────────────────────────────────────────────
# Bind address. Unset → 0.0.0.0. Bind 127.0.0.1 / an internal interface for the
# private-network stance (§13).
FLEET_HOST=
# HTTP/WS port.
FLEET_PORT=7350
# Trust X-Forwarded-For from a front proxy (§13). true|false (default false).
# Enable ONLY behind a trusted TLS-terminating proxy/mesh, so the per-IP failed-auth
# throttle and audit logs key on the real client IP instead of the proxy's single
# address. Leave off for direct exposure — a spoofable header must not be trusted.
FLEET_TRUST_PROXY=false

# ── Credentials (§13) — comma-separated for zero-downtime key rotation ─────────
# Agent auth key(s) (WS subprotocol ticket). Required; auto-generated in dev only.
FLEET_AGENT_KEY=
# REST admin key(s) (Bearer). Required when the REST API is enabled.
FLEET_ADMIN_KEY=

# ── Tunables (§12) ──────────────────────────────────────────────────────────────
# Agent heartbeat interval (ms). Orchestrator is the single source of truth.
FLEET_HEARTBEAT_MS=5000
# Command ack timeout (ms).
FLEET_COMMAND_TIMEOUT_MS=10000
# CORS allow-origins, comma-separated. Empty → off (same-origin only).
FLEET_CORS_ORIGINS=
# Allow ?key= auth on /v1/events for browser EventSource. true|false (default false).
# Insecure (query strings hit proxy logs) — prefer the Authorization header (§10, §13).
FLEET_SSE_QUERY_AUTH=false
# Log level: trace|debug|info|warn|error.
FLEET_LOG_LEVEL=info
