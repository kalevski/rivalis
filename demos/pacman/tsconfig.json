{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "types": ["node"],
        "noEmit": true,
        "noUncheckedIndexedAccess": false
    },
    "include": ["src/**/*", "vite.config.ts"],
    "ts-node": {
        "transpileOnly": true,
        "compilerOptions": {
            "module": "CommonJS",
            "moduleResolution": "Node"
        }
    }
}
